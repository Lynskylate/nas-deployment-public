apiVersion: v1
kind: Secret
metadata:
  name: repo-{{ argocd_repo_url | regex_replace('[^a-zA-Z0-9]', '-') | lower }}
  namespace: {{ argocd_namespace }}
  labels:
    argocd.argoproj.io/secret-type: repository
stringData:
  url: {{ argocd_repo_url }}
  sshPrivateKey: |
{{ argocd_repo_ssh_key | indent(4, true) }}
