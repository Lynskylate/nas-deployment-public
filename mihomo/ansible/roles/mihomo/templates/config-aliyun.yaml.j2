---
# Mihomo Configuration for Aliyun Server
# HTTP Proxy Mode with Envoy Integration
# Generated by Ansible

# General Configuration
mode: {{ mihomo_mode }}
log-level: {{ mihomo_log_level }}
allow-lan: {{ mihomo_allow_lan | lower }}
bind-address: "127.0.0.1"
ipv6: true
external-controller: {{ mihomo_external_controller }}
external-ui: ui
secret: "{{ mihomo_secret }}"
geodata-mode: true
geox-url:
  geoip: "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip.dat"
  geosite: "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat"
  mmdb: "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip.metadb"

# DNS Configuration
dns:
  enable: true
  listen: 127.0.0.1:5353
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - '*.lan'
    - 'localhost.ptlogin2.qq.com'
  nameserver:
    - 1.1.1.1
    - 8.8.8.8
  fallback:
    - 208.67.222.222
    - 208.67.220.220

{% if proxy_provider_url is defined %}
# Proxy Providers
proxy-providers:
  subscription:
    type: http
    url: {{ proxy_provider_url }}
    path: ./providers/subscription.yaml
    interval: {{ proxy_provider_interval }}
    health-check:
      enable: true
      url: https://www.gstatic.com/generate_204
      interval: 300
    filter: ''
{% endif %}

# Proxies (ShadowTLS outbound)
proxies:
  - name: "ShadowTLS-Outbound"
    type: ss
    server: {{ shadowtls_server }}
    port: {{ shadowtls_port }}
    cipher: {{ shadowsocks_method }}
    password: {{ shadowsocks_password }}
    plugin: shadow-tls
    plugin-opts:
      host: {{ shadowtls_sni }}
      password: {{ shadowtls_password }}
      version: 3

# Proxy Groups
proxy-groups:
  - name: "Proxy"
    type: select
    proxies:
      - ShadowTLS-Outbound
      - DIRECT
    url: https://www.gstatic.com/generate_204
    interval: 300

  - name: "Auto"
    type: url-test
    proxies:
      - ShadowTLS-Outbound
      - DIRECT
    url: https://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50

  # AI services (use ShadowTLS to avoid HK nodes)
  - name: "AI"
    type: select
    proxies:
      - ShadowTLS-Outbound
      - Auto
    url: https://www.gstatic.com/generate_204
    interval: 300

  - name: "AdBlock"
    type: select
    proxies:
      - REJECT
      - DIRECT

# Rules
rules:
  # Local network - DIRECT
  - DOMAIN-SUFFIX,local,DIRECT
  - IP-CIDR,127.0.0.0/8,DIRECT
  - IP-CIDR,172.16.0.0/12,DIRECT
  - IP-CIDR,192.168.0.0/16,DIRECT
  - IP-CIDR,10.0.0.0/8,DIRECT
  - IP-CIDR,17.0.0.0/8,DIRECT

  # Chinese services - DIRECT
  - DOMAIN-SUFFIX,cn,DIRECT
  - DOMAIN-KEYWORD,baidu,DIRECT
  - DOMAIN-KEYWORD,taobao,DIRECT
  - DOMAIN-KEYWORD,alipay,DIRECT
  - DOMAIN-KEYWORD,tmall,DIRECT
  - DOMAIN-KEYWORD,jd.com,DIRECT
  - DOMAIN-KEYWORD,bilibili,DIRECT
  - DOMAIN-KEYWORD,netease,DIRECT
  - DOMAIN-KEYWORD,qq,DIRECT
  - DOMAIN-KEYWORD,weixin,DIRECT
  - GEOIP,CN,DIRECT

  # Streaming services
  - DOMAIN-SUFFIX,youtube.com,Auto
  - DOMAIN-SUFFIX,ytimg.com,Auto
  - DOMAIN-SUFFIX,googlevideo.com,Auto
  - DOMAIN-SUFFIX,netflix.com,Auto
  - DOMAIN-SUFFIX,nflxvideo.net,Auto
  - DOMAIN-SUFFIX,disney.com,Auto
  - DOMAIN-SUFFIX,disneyplus.com,Auto
  - DOMAIN-SUFFIX,disney-plus.com,Auto
  - DOMAIN-SUFFIX,hulu.com,Auto
  - DOMAIN-SUFFIX,hbomax.com,Auto
  - DOMAIN-SUFFIX,primevideo.com,Auto
  - DOMAIN-SUFFIX,twitch.tv,Auto

  # Telegram
  - DOMAIN-SUFFIX,telegram.org,Auto
  - DOMAIN-SUFFIX,t.me,Auto
  - DOMAIN-SUFFIX,tdesktop.com,Auto
  - IP-CIDR,91.108.0.0/16,Auto
  - IP-CIDR,109.239.140.0/24,Auto
  - IP-CIDR,149.154.160.0/20,Auto

  # GitHub
  - DOMAIN-SUFFIX,github.com,Auto
  - DOMAIN-SUFFIX,githubusercontent.com,Auto
  - DOMAIN-SUFFIX,githubassets.com,Auto

  # Google services
  - DOMAIN-SUFFIX,google.com,Auto
  - DOMAIN-SUFFIX,googleapis.com,Auto
  - DOMAIN-SUFFIX,googleusercontent.com,Auto
  - DOMAIN-SUFFIX,gstatic.com,Auto
  - DOMAIN-SUFFIX,googletagmanager.com,Auto
  - DOMAIN-SUFFIX,google-analytics.com,Auto

  # OpenAI / ChatGPT
  - DOMAIN-SUFFIX,openai.com,AI
  - DOMAIN-SUFFIX,chatgpt.com,AI
  - DOMAIN-SUFFIX,oaistatic.com,AI
  - DOMAIN-SUFFIX,oaiusercontent.com,AI
  - DOMAIN-SUFFIX,auth0.com,AI

  # Google Gemini / AI Studio
  - DOMAIN-SUFFIX,gemini.google.com,AI
  - DOMAIN-SUFFIX,generativelanguage.googleapis.com,AI
  - DOMAIN-SUFFIX,ai.google.dev,AI
  - DOMAIN-SUFFIX,aistudio.google.com,AI
  - DOMAIN-SUFFIX,makersuite.google.com,AI

  # Microsoft
  - DOMAIN-SUFFIX,microsoft.com,Auto
  - DOMAIN-SUFFIX,office.com,Auto
  - DOMAIN-SUFFIX,skype.com,Auto
  - DOMAIN-SUFFIX,linkedin.com,Auto

  # Apple services
  - DOMAIN-SUFFIX,apple.com,Auto
  - DOMAIN-SUFFIX,icloud.com,Auto
  - DOMAIN-SUFFIX,cdn-apple.com,Auto

  # Social media
  - DOMAIN-SUFFIX,twitter.com,Auto
  - DOMAIN-SUFFIX,x.com,Auto
  - DOMAIN-SUFFIX,facebook.com,Auto
  - DOMAIN-SUFFIX,instagram.com,Auto
  - DOMAIN-SUFFIX,tiktok.com,Auto
  - DOMAIN-SUFFIX,tiktokcdn.com,Auto

  # Development tools
  - DOMAIN-SUFFIX,stackoverflow.com,Auto
  - DOMAIN-SUFFIX,cloudflare.com,Auto
  - DOMAIN-SUFFIX,docker.com,Auto

  # Default rule - use Auto group
  - MATCH,Auto

# Listeners
listeners:
  # Local HTTP proxy listener (no auth)
  - name: http-local
    type: http
    port: {{ mihomo_mixed_port }}
    bind: "127.0.0.1"

  # Public HTTP proxy listener (with authentication)
  - name: http-public
    type: http
    port: 8888
    bind: "0.0.0.0"
    authentication:
      - "http-basic"
    http-users:
      - "{{ proxy_auth_username }}:{{ proxy_auth_password }}"
