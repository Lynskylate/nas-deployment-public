# Normalize all text files to LF
* text=auto eol=lf

# Ansible / config templates
*.j2 text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.conf text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# Python / source
*.py text eol=lf
*.pyi text eol=lf

# Makefiles
Makefile text eol=lf
makefile text eol=lf
*.mk text eol=lf

# GitHub Actions / CI
*.action text eol=lf
*.workflow text eol=lf

# Binary files (do not normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.xz binary
*.so binary
*.bin binary
